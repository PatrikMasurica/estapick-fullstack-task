// This is your database connection configuration
datasource db {
  provider = "postgresql"

}

// This is the Prisma Client generator
generator client {
  provider = "prisma-client-js"
}

model Listing {
  id          String   @id @default(cuid())

  title       String
  description String

  price       Int
  bedrooms    Int
  bathrooms   Int

  city        String
  address     String

  latitude    Float
  longitude   Float

   images      Json     

  createdAt   DateTime @default(now())
}