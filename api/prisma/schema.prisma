// This is your database connection configuration
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// This is the Prisma Client generator
generator client {
  provider = "prisma-client-js"
}

model Listing {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Int
  bedrooms    Int
  bathrooms   Int
  city        String
  address     String
  latitude    Float
  longitude   Float
  images      Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}